{% extends 'base.html.twig' %}

{% block title %}Inscription - {{ evenement.titre }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="mb-2">✅ S'inscrire à :</h1>
        <h3 class="text-muted mb-4">{{ evenement.titre }}</h3>

        <div class="alert alert-info">
            📅 {{ evenement.dateDebut|date('d/m/Y H:i') }}<br>
            📍 {{ evenement.lieu }}<br>
            💰 {{ evenement.prix }} €
        </div>

        {{ form_start(form) }}

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="mb-3">
                    {{ form_label(form.commentaire) }}
                    {{ form_widget(form.commentaire) }}
                    {{ form_errors(form.commentaire) }}
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success btn-lg">✅ Confirmer l'inscription</button>
            <a href="{{ path('app_evenements_detail', {id: evenement.id}) }}" class="btn btn-outline-secondary">← Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}