{% extends 'base.html.twig' %}

{% block title %}Nouvel événement{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <h1 class="mb-4">➕ Créer un événement</h1>

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

        <div class="card shadow-sm">
            <div class="card-body">

                <div class="mb-3">
                    {{ form_label(form.titre) }}
                    {{ form_widget(form.titre) }}
                    {{ form_errors(form.titre) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.dateDebut) }}
                        {{ form_widget(form.dateDebut) }}
                        {{ form_errors(form.dateDebut) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.dateFin) }}
                        {{ form_widget(form.dateFin) }}
                        {{ form_errors(form.dateFin) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.lieu) }}
                    {{ form_widget(form.lieu) }}
                    {{ form_errors(form.lieu) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.lieu_event) }}
                    {{ form_widget(form.lieu_event) }}
                    {{ form_errors(form.lieu_event) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.capaciteMax) }}
                        {{ form_widget(form.capaciteMax) }}
                        {{ form_errors(form.capaciteMax) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.prix) }}
                        {{ form_widget(form.prix) }}
                        {{ form_errors(form.prix) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.categorie) }}
                        {{ form_widget(form.categorie) }}
                        {{ form_errors(form.categorie) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.status) }}
                        {{ form_widget(form.status) }}
                        {{ form_errors(form.status) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.tagEvenements) }}
                    <div class="border rounded p-3">
                        {{ form_widget(form.tagEvenements) }}
                    </div>
                    {{ form_errors(form.tagEvenements) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.imageFile) }}
                    {{ form_widget(form.imageFile) }}
                    {{ form_errors(form.imageFile) }}
                </div>

            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">✅ Créer l'événement</button>
            <a href="{{ path('app_evenements_liste') }}" class="btn btn-outline-secondary">← Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}