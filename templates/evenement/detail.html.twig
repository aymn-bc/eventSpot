{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-8">
        <h1 class="mb-3">{{ evenement.titre }}</h1>

        {% if evenement.imageName %}
            <img src="{{ asset('uploads/images/' ~ evenement.imageName) }}" class="img-fluid rounded mb-4" style="max-height:400px; width:100%; object-fit:cover;">
        {% endif %}

        <p class="text-muted">
            📅 {{ evenement.dateDebut|date('d/m/Y H:i') }} → {{ evenement.dateFin|date('d/m/Y H:i') }}
        </p>

        <p>{{ evenement.description }}</p>

        <hr>

        <p><strong>📍 Lieu :</strong> {{ evenement.lieu }}</p>
        <p><strong>💰 Prix :</strong> {{ evenement.prix }} €</p>

        {# Catégorie #}
        <p><strong>Catégorie :</strong>
            {% if evenement.categorie.value == 'conference' %}
                <span class="badge bg-primary">🎤 Conférence</span>
            {% elseif evenement.categorie.value == 'atelier' %}
                <span class="badge bg-warning text-dark">🔧 Atelier</span>
            {% elseif evenement.categorie.value == 'meetup' %}
                <span class="badge bg-info text-dark">👥 Meetup</span>
            {% elseif evenement.categorie.value == 'formation' %}
                <span class="badge bg-secondary">📚 Formation</span>
            {% elseif evenement.categorie.value == 'concert' %}
                <span class="badge bg-danger">🎵 Concert</span>
            {% endif %}
        </p>

        {# Statut #}
        <p><strong>Statut :</strong>
            {% if evenement.status.value == 'brouillon' %}
                <span class="badge bg-secondary">📝 Brouillon</span>
            {% elseif evenement.status.value == 'publie' %}
                <span class="badge bg-success">🟢 Publié</span>
            {% elseif evenement.status.value == 'complet' %}
                <span class="badge bg-danger">🔴 Complet</span>
            {% elseif evenement.status.value == 'annule' %}
                <span class="badge bg-dark">⚫ Annulé</span>
            {% endif %}
        </p>

        {# Tags #}
        {% if evenement.tagEvenements|length > 0 %}
        <p><strong>🏷 Tags :</strong>
            {% for tag in evenement.tagEvenements %}
                <span class="badge" style="background-color: {{ tag.couleur }}">{{ tag.nom }}</span>
            {% endfor %}
        </p>
        {% endif %}

        {# Stats du service EvenementManager #}
        <div class="mt-4 p-3 bg-light rounded">
            <h5>📊 Statistiques</h5>
            <p><strong>👥 Inscrits :</strong> {{ nbInscrits }} / {{ evenement.capaciteMax }}</p>
            <p><strong>🪑 Places restantes :</strong> {{ placesRestantes }}</p>

            {# Jauge de remplissage #}
            {% set pourcentage = evenement.capaciteMax > 0 ? ((nbInscrits / evenement.capaciteMax) * 100)|round : 0 %}
            <div class="progress mt-2" style="height: 20px;">
                <div class="progress-bar
                    {% if pourcentage >= 100 %}bg-danger
                    {% elseif pourcentage >= 75 %}bg-warning
                    {% else %}bg-success{% endif %}"
                    style="width: {{ pourcentage }}%">
                    {{ pourcentage }}%
                </div>
            </div>
        </div>

        <div class="mt-4">
            {% if evenement.status.value == 'complet' %}
                <button class="btn btn-secondary" disabled>🔴 Complet</button>
            {% elseif estInscrit %}
                <button class="btn btn-secondary" disabled>✅ Déjà inscrit</button>
            {% else %}
                <a href="{{ path('app_evenements_inscription', {id: evenement.id}) }}" class="btn btn-success btn-lg">✅ S'inscrire</a>
            {% endif %}

            {% if is_granted('ROLE_ORGANISATEUR') %}
                <a href="{{ path('app_evenements_modifier', {id: evenement.id}) }}" class="btn btn-warning ms-2">✏️ Modifier</a>
            {% endif %}
            <a href="{{ path('app_evenements_liste') }}" class="btn btn-outline-secondary ms-2">← Retour</a>
        </div>
    </div>
</div>
{% endblock %}