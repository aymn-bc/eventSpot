{% extends 'base.html.twig' %}

{% block title %}Liste des lieux{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📍 Lieux</h1>
    <a href="{{ path('app_lieux_nouveau') }}" class="btn btn-success">+ Nouveau lieu</a>
</div>

{% if lieux is empty %}
    <div class="alert alert-info">Aucun lieu trouvé.</div>
{% else %}
<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nom</th>
            <th>Adresse</th>
            <th>Ville</th>
            <th>Capacité</th>
        </tr>
    </thead>
    <tbody>
    {% for lieu in lieux %}
        <tr>
            <td><strong>{{ lieu.nom }}</strong></td>
            <td>{{ lieu.adresse }}</td>
            <td>{{ lieu.ville }}</td>
            <td>{{ lieu.capacite }} personnes</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}