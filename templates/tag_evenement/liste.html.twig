{% extends 'base.html.twig' %}

{% block title %}Liste des tags{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>🏷 Tags</h1>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_tags_nouveau') }}" class="btn btn-success">+ Nouveau tag</a>
    {% endif %}
</div>

{% if tags is empty %}
    <div class="alert alert-info">Aucun tag trouvé.</div>
{% else %}
<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nom</th>
            <th>Couleur</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for tag in tags %}
        <tr>
            <td>
                <span class="badge" style="background-color: {{ tag.couleur }}">{{ tag.nom }}</span>
            </td>
            <td>
                <span class="d-inline-block rounded" style="width:30px; height:30px; background-color: {{ tag.couleur }};"></span>
                {{ tag.couleur }}
            </td>
            <td>
                {% if is_granted('ROLE_ADMIN') %}
                    <form method="post" action="{{ path('app_tags_supprimer', {id: tag.id}) }}" style="display:inline" class="js-delete">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tag.id) }}">
                        <button class="btn btn-sm btn-danger">🗑 Supprimer</button>
                    </form>
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}