{% extends 'base.html.twig' %}

{% block title %}Nouveau tag{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h1 class="mb-4">➕ Ajouter un tag</h1>

        {{ form_start(form) }}
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="mb-3">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom) }}
                    {{ form_errors(form.nom) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.couleur) }}
                    {{ form_widget(form.couleur) }}
                    {{ form_errors(form.couleur) }}
                </div>
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">✅ Créer le tag</button>
            <a href="{{ path('app_tags_liste') }}" class="btn btn-outline-secondary">← Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}